{
  // Use IntelliSense to learn about possible attributes.
  // Hover to view descriptions of existing attributes.
  // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
  "version": "0.2.0",
  "inputs": [
    {
      "type": "promptString",
      "id": "HUC",
      "description": "What HUC?",
      "default": "0808010105" // Really small HUC
    },
    {
      "id": "environment",
      "type": "pickString",
      "description": "Select a REPORTING API environment",
      "options": [
        "staging",
        "production",
        "local"
      ],
      "default": "production"
    },
  ],
  "configurations": [
    {
      "name": "🐍 Python: Run/Debug Current File",
      "type": "debugpy",
      "request": "launch",
      "program": "${file}",
      "cwd": "${workspaceFolder:📦 pyreports}/python",
      "envFile": "${workspaceFolder:📦 pyreports}/.env",
      "args": ["${input:environment}"],
      "env": {
        "ENVIRONMENT": "${input:environment}",
        "PYTHONPATH": "${workspaceFolder:📦 pyreports}/python"
      },
      "console": "integratedTerminal",
      "justMyCode": true
    },
    {
      "name": "⚠️🐍 Python: Update Schema",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder:📦 pyreports}/python/scripts/update_schema.py",
      "cwd": "${workspaceFolder:📦 pyreports}/python",
      "env": {
        "PYTHONPATH": "${workspaceFolder:📦 pyreports}/python"
      },
      "console": "integratedTerminal",
      "justMyCode": true
    },
    {
      "name": "🟦 TypeScript: Create Report",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "${env:NVM_BIN}/node",
      "runtimeArgs": [
        "-r",
        "ts-node/register"
      ],
      "args": [
        "${workspaceFolder:📦 pyreports}/typescript/scripts/createReport.ts",
        "${input:environment}"
      ],
      "cwd": "${workspaceFolder:📦 pyreports}/typescript",
      "console": "integratedTerminal",
    },
    {
      "name": "🟦 TypeScript: Run Current File",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "${env:NVM_BIN}/node",
      "runtimeArgs": [
        "-r",
        "ts-node/register"
      ],
      "args": [
        "${file}",
        "${input:environment}"
      ],
      "cwd": "${workspaceFolder:📦 pyreports}/typescript",
      "console": "integratedTerminal",
    },
 ]
}